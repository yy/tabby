#!/bin/zsh
set -euo pipefail

# Close duplicate browser tabs (keeps the first occurrence of each URL).

source "${0:A:h}/tabby-common"

usage="Usage: tabby dedup [--dry-run]"

if [[ "${1:-}" == "--help" ]]; then
    echo "$usage"
    echo "  --dry-run   Show what would be closed without closing"
    exit 0
fi

dry_run=false
case $# in
    0) ;;
    1)
        [[ "$1" == "--dry-run" ]] || usage_error "$usage"
        dry_run=true
        ;;
    *)
        usage_error "$usage"
        ;;
esac

{
cat "$BROWSER_JS"
cat <<'JS'
const browser = getBrowser();
const args = $.NSProcessInfo.processInfo.arguments.js;
const dryRun = args[4].js === "true";
const seen = {};
const toClose = [];

const windows = browser.windows();
for (let wi = 0; wi < windows.length; wi++) {
    const tabs = browser.tabs(windows[wi]);
    for (let ti = 0; ti < tabs.length; ti++) {
        const url = browser.tabUrl(tabs[ti]);
        if (seen[url]) {
            toClose.push({wi, ti, title: browser.tabTitle(tabs[ti]), url});
        } else {
            seen[url] = true;
        }
    }
}

if (toClose.length === 0) {
    "No duplicates found.";
} else if (dryRun) {
    const lines = toClose.map(t => `Would close: ${t.title} (${t.url})`);
    lines.push(`\n${toClose.length} duplicate(s) found.`);
    lines.join("\n");
} else {
    for (let i = toClose.length - 1; i >= 0; i--) {
        const t = toClose[i];
        browser.tabs(browser.windows()[t.wi])[t.ti].close();
    }
    `Closed ${toClose.length} duplicate tab(s).`;
}
JS
} | /usr/bin/osascript -l JavaScript - "$dry_run"
