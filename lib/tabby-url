#!/bin/zsh
set -euo pipefail

# Get the URL of a browser tab.

source "${0:A:h}/tabby-common"

usage="Usage: tabby url [<window> <tab>]"

if [[ "${1:-}" == "--help" ]]; then
    echo "$usage"
    echo "  With no args, prints the URL of the active tab."
    echo "  With args, prints the URL of the specified tab."
    exit 0
fi

if [[ $# -eq 0 ]]; then
    {
    cat "$BROWSER_JS"
    cat <<'JS'
const browser = getBrowser();
const windows = browser.windows();
if (windows.length === 0) {
    fail("tabby: no browser windows are open");
}
browser.tabUrl(browser.activeTab(windows[0]));
JS
    } | osascript -l JavaScript -
elif [[ $# -eq 2 ]]; then
    require_positive_int "window" "$1" "$usage"
    require_positive_int "tab" "$2" "$usage"
    {
    cat "$BROWSER_JS"
    cat <<'JS'
const browser = getBrowser();
const args = $.NSProcessInfo.processInfo.arguments.js;
const wi = parseInt(args[4].js);
const ti = parseInt(args[5].js);

const windows = browser.windows();
if (wi > windows.length) {
    fail(`tabby: window ${wi} does not exist`);
}

const tabs = browser.tabs(windows[wi - 1]);
if (ti > tabs.length) {
    fail(`tabby: tab ${ti} does not exist in window ${wi}`);
}

browser.tabUrl(tabs[ti - 1]);
JS
    } | osascript -l JavaScript - "$1" "$2"
else
    usage_error "$usage"
fi
