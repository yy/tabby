#!/bin/zsh
set -euo pipefail

# List all Chrome tabs as JSON.
# Output: array of {window, tab, title, url} objects.

if [[ "${1:-}" == "--help" ]]; then
    echo "Usage: tabby list [--window N]"
    echo "  List all Chrome tabs as JSON."
    echo "  --window N   Only list tabs in window N"
    exit 0
fi

window_filter=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --window) window_filter="$2"; shift 2 ;;
        *) echo "Usage: tabby list [--window N]" >&2; exit 1 ;;
    esac
done

osascript -l JavaScript - "$window_filter" <<'JS'
const chrome = Application("Google Chrome");
const windowFilter = $.NSProcessInfo.processInfo.arguments.js[4].js;
const result = [];
const windows = chrome.windows();
for (let wi = 0; wi < windows.length; wi++) {
    if (windowFilter && String(wi + 1) !== windowFilter) continue;
    const tabs = windows[wi].tabs();
    for (let ti = 0; ti < tabs.length; ti++) {
        result.push({
            window: wi + 1,
            tab: ti + 1,
            title: tabs[ti].title(),
            url: tabs[ti].url()
        });
    }
}
JSON.stringify(result);
JS
