#!/bin/zsh
set -euo pipefail

# List browser tabs as JSON.
# Output: array of {window, tab, title, url} objects.

source "${0:A:h}/tabby-common"

usage="Usage: tabby list [--window N]"

if [[ "${1:-}" == "--help" ]]; then
    echo "$usage"
    echo "  List all tabs as JSON."
    echo "  --window N   Only list tabs in window N"
    exit 0
fi

window_filter=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --window)
            [[ $# -ge 2 ]] || usage_error "$usage"
            require_positive_int "window" "$2" "$usage"
            window_filter="$2"
            shift 2
            ;;
        *)
            usage_error "$usage"
            ;;
    esac
done

{
cat "$BROWSER_JS"
cat <<'JS'
const browser = getBrowser();
const windowFilter = $.NSProcessInfo.processInfo.arguments.js[4].js;
const result = [];
const windows = browser.windows();
for (let wi = 0; wi < windows.length; wi++) {
    if (windowFilter && String(wi + 1) !== windowFilter) continue;
    const tabs = browser.tabs(windows[wi]);
    for (let ti = 0; ti < tabs.length; ti++) {
        result.push({
            window: wi + 1,
            tab: ti + 1,
            title: browser.tabTitle(tabs[ti]),
            url: browser.tabUrl(tabs[ti])
        });
    }
}
JSON.stringify(result);
JS
} | /usr/bin/osascript -l JavaScript - "$window_filter"
