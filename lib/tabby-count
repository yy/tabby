#!/bin/zsh
set -euo pipefail

# Count browser tabs.

source "${0:A:h}/tabby-common"

usage="Usage: tabby count [--total]"

if [[ "${1:-}" == "--help" ]]; then
    echo "$usage"
    echo "  Count open tabs per window."
    echo "  --total   Print only the total number"
    exit 0
fi

total_only=false
case $# in
    0) ;;
    1)
        [[ "$1" == "--total" ]] || usage_error "$usage"
        total_only=true
        ;;
    *)
        usage_error "$usage"
        ;;
esac

{
cat "$BROWSER_JS"
cat <<'JS'
const browser = getBrowser();
const args = $.NSProcessInfo.processInfo.arguments.js;
const totalOnly = args[4].js === "true";
const windows = browser.windows();
let total = 0;
const lines = [];
for (let wi = 0; wi < windows.length; wi++) {
    const count = browser.tabs(windows[wi]).length;
    total += count;
    lines.push(`Window ${wi + 1}: ${count} tabs`);
}
if (totalOnly) {
    `${total}`;
} else {
    lines.push(`Total: ${total}`);
    lines.join("\n");
}
JS
} | osascript -l JavaScript - "$total_only"
