#!/bin/zsh
set -euo pipefail

# tabby — a Mac CLI for herding browser tabs

TABBY_ROOT="${0:A:h:h}"
LIBDIR="$TABBY_ROOT/lib"

usage() {
    cat <<'USAGE'
tabby — herd your browser tabs

Usage: tabby [--browser chrome|safari] <command> [options]

Commands:
  list          List all tabs as JSON
  count         Count open tabs
  url           Get URL of active or specific tab
  close         Close a tab by window/tab index
  dedup         Close duplicate tabs
  help          Show this help

Global options:
  --browser     Browser to control (chrome or safari, default: chrome)
                Also settable via TABBY_BROWSER env var.

Options vary by command. Run `tabby <command> --help` for details.
USAGE
}

# Parse global flags before subcommand
while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --browser)
            [[ $# -ge 2 ]] || { echo "tabby: --browser requires an argument" >&2; exit 1; }
            export TABBY_BROWSER="$2"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

cmd="${1:-help}"
shift 2>/dev/null || true

# Validate command name: alphanumeric and hyphens only (prevent path traversal)
if [[ ! "$cmd" =~ ^[a-zA-Z][a-zA-Z0-9-]*$ ]]; then
    if [[ "$cmd" == "help" || "$cmd" == "--help" || "$cmd" == "-h" ]]; then
        usage
        exit 0
    fi
    print -r "tabby: unknown command '$cmd'" >&2
    echo "Run 'tabby help' for usage." >&2
    exit 1
fi

subcmd="$LIBDIR/tabby-$cmd"
if [[ -x "$subcmd" ]]; then
    exec "$subcmd" "$@"
elif [[ "$cmd" == "help" ]]; then
    usage
else
    print -r "tabby: unknown command '$cmd'" >&2
    echo "Run 'tabby help' for usage." >&2
    exit 1
fi
